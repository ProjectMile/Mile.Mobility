<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Target Name="MileMobilityBuildNativeSource" BeforeTargets="BeforeClCompile">
    <ItemGroup>
      <ClCompile Include="$(MSBuildThisFileDirectory)..\..\Source\Native\Mile.Mobility.Utilities.FixedInteger.c" />
      <ClCompile Include="$(MSBuildThisFileDirectory)..\..\Source\Native\Mile.Mobility.Utilities.MemoryAccess.c" />
    </ItemGroup>
  </Target>
</Project>